\begin_layout Subsection
Signatures
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
S_{3}=\left[\begin{array}{c}
\left[\begin{array}{cc}
\sigma_{1,1,1} & \sigma_{1,1,2}\\
\sigma_{1,2,1} & \sigma_{1,2,2}
\end{array}\right]\\
\\\left[\begin{array}{cc}
\sigma_{2,1,1} & \sigma_{2,1,2}\\
\sigma_{2,2,1} & \sigma_{2,2,2}
\end{array}\right]
\end{array}\right]
\end{equation}

\end_inset


\end_layout

\begin_layout Subsection
Core Signatures
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
C_{3}=\left\{ s_{1},s_{2},s_{1,2},s_{1,1,2},s_{1,2,2}\right\} 
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
S_{3}=\left[\begin{array}{c}
\left[\begin{array}{cc}
\frac{1}{6}\left(s_{1}\right)^{3} & s_{1,1,2}\\
s_{1}s_{1,2}-2s_{1,1,2} & s_{1,2,2}
\end{array}\right]\\
\\\left[\begin{array}{cc}
\frac{1}{2}\left(s_{1}\right)^{2}s_{2}-s_{1}s_{1,2}+s_{1,1,2} & s_{2}s_{1,2}-2s_{1,2,2}\\
\frac{1}{2}s_{1}\left(s_{2}\right)^{2}-s_{2}s_{1,2}+s_{1,2,2} & \frac{1}{6}\left(s_{2}\right)^{3}
\end{array}\right]
\end{array}\right]
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray}
s_{1} & = & \sqrt[3]{6\sigma_{1,1,1}}\\
s_{2} & = & \sqrt[3]{6\sigma_{2,2,2}}\\
s_{1,2} & = & \frac{\sigma_{1,2,1}+2\sigma_{1,1,2}}{\sqrt[3]{6\sigma_{1,1,1}}}=\frac{\sigma_{2,1,2}+2\sigma_{1,2,2}}{\sqrt[3]{6\sigma_{2,2,2}}}\\
s_{1,1,2} & = & \sigma_{1,1,2}\\
s_{1,2,2} & = & \sigma_{1,2,2}
\end{eqnarray}

\end_inset


\end_layout

