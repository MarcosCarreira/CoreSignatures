\end_layout

\begin_layout Standard
Cayley's hyperdeterminant:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray}
\Delta_{222} & = & \left(\sigma_{1,1,1}\right)^{2}\left(\sigma_{2,2,2}\right)^{2}+\left(\sigma_{1,2,1}\right)^{2}\left(\sigma_{2,1,2}\right)^{2}+\left(\sigma_{1,1,2}\right)^{2}\left(\sigma_{2,2,1}\right)^{2}+\left(\sigma_{1,2,2}\right)^{2}\left(\sigma_{2,1,1}\right)^{2}\\
 &  & +4\left(\sigma_{1,1,1}\sigma_{1,2,2}\sigma_{2,1,2}\sigma_{2,2,1}+\sigma_{1,1,2}\sigma_{1,2,1}\sigma_{2,1,1}\sigma_{2,2,2}\right)\nonumber \\
 &  & -2\left(\begin{array}{c}
+\sigma_{1,1,1}\sigma_{1,1,2}\sigma_{2,2,1}\sigma_{2,2,2}+\sigma_{1,1,1}\sigma_{1,2,1}\sigma_{2,1,2}\sigma_{2,2,2}\\
+\sigma_{1,1,1}\sigma_{1,2,2}\sigma_{2,1,1}\sigma_{2,2,2}+\sigma_{1,1,2}\sigma_{1,2,1}\sigma_{2,1,2}\sigma_{2,2,1}\\
+\sigma_{1,1,2}\sigma_{1,2,2}\sigma_{2,1,1}\sigma_{2,2,1}+\sigma_{1,2,1}\sigma_{1,2,2}\sigma_{2,1,1}\sigma_{2,1,2}
\end{array}\right)\nonumber 
\end{eqnarray}

\end_inset


\end_layout

\begin_layout Standard
Substituting the Core Signatures:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{eqnarray}
\Delta_{222} & = & \frac{1}{1296}\left(\left(s_{1}\right)^{2}\left(s_{2}\right)^{2}+6s_{1}s_{1,2,2}+6s_{2}s_{1,1,2}-6s_{1}s_{2}s_{1,2}\right)^{2}\cdot\\
 &  & \cdot\left(\left(6s_{1,2}+s_{1}s_{2}\right)^{2}-48\left(s_{1}s_{1,2,2}+s_{2}s_{1,1,2}\right)\right)\nonumber 
\end{eqnarray}

\end_inset


\end_layout

\begin_layout Standard
With a much simpler positivity condition:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
\left(6s_{1,2}+s_{1}s_{2}\right)^{2}>48\left(s_{1}s_{1,2,2}+s_{2}s_{1,1,2}\right)
\end{equation}

\end_inset


\end_layout

