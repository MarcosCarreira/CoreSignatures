Cell[BoxData[
 RowBox[{
  RowBox[{"SymbolicCPDecomposition222", "[", "tensor_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "X1", ",", "X2", ",", "eigen", ",", "A", ",", "B", ",", "C", ",", 
      "diag1", ",", "diag2", ",", "rec"}], "}"}], ",", 
    RowBox[{"(*", 
     RowBox[{
     "1.", " ", "Extract", " ", "the", " ", "two", " ", "slices", " ", 
      "along", " ", "the", " ", "3", "rd", " ", "dimension"}], "*)"}], 
    RowBox[{
     RowBox[{"X1", "=", 
      RowBox[{"tensor", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "All", ",", "1"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"X2", "=", 
      RowBox[{"tensor", "[", 
       RowBox[{"[", 
        RowBox[{"All", ",", "All", ",", "2"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"2.", " ", "Find", " ", "Eigenvectors", " ", "of", " ", 
       RowBox[{"X1", ".", 
        RowBox[{"Inverse", "[", "X2", "]"}]}], " ", "to", " ", "get", " ", 
       "Factor", " ", "A"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Note", ":", 
       RowBox[{
       "We", " ", "transpose", " ", "because", " ", "Eigenvectors", " ", 
        "returns", " ", "row", " ", "vectors"}]}], "*)"}], 
     RowBox[{"A", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{"X1", ".", 
         RowBox[{"Inverse", "[", "X2", "]"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"3.", " ", "Find", " ", "Eigenvectors", " ", "of", " ", 
       RowBox[{
        RowBox[{"X1", "^", "T"}], ".", 
        RowBox[{"Inverse", "[", 
         RowBox[{"X2", "^", "T"}], "]"}]}], " ", "to", " ", "get", " ", 
       "Factor", " ", "B"}], "*)"}], 
     RowBox[{"B", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Eigenvectors", "[", 
        RowBox[{
         RowBox[{"Transpose", "[", "X1", "]"}], ".", 
         RowBox[{"Inverse", "[", 
          RowBox[{"Transpose", "[", "X2", "]"}], "]"}]}], "]"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{
       "4.", " ", "Solve", " ", "for", " ", "Factor", " ", "C", " ", "using", 
        " ", "the", " ", "relationship", " ", "X1"}], "=", 
       RowBox[{
        RowBox[{"A", ".", "diag"}], 
        RowBox[{
         RowBox[{"(", "c1", ")"}], ".", 
         RowBox[{"B", "^", "T"}]}]}]}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{
      "We", " ", "use", " ", "LinearSolve", " ", "to", " ", "find", " ", 
       "the", " ", "diagonal", " ", "elements", " ", "of", " ", "C"}], "*)"}], 
     RowBox[{"diag1", "=", 
      RowBox[{"Diagonal", "[", 
       RowBox[{
        RowBox[{"Inverse", "[", "A", "]"}], ".", "X1", ".", 
        RowBox[{"Inverse", "[", 
         RowBox[{"Transpose", "[", "B", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"diag2", "=", 
      RowBox[{"Diagonal", "[", 
       RowBox[{
        RowBox[{"Inverse", "[", "A", "]"}], ".", "X2", ".", 
        RowBox[{"Inverse", "[", 
         RowBox[{"Transpose", "[", "B", "]"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"C", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"{", 
        RowBox[{"diag1", ",", "diag2"}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Return", " ", "the", " ", "Factor", " ", "Matrices", " ", 
       RowBox[{"{", 
        RowBox[{"A", ",", "B", ",", "C"}], "}"}]}], "*)"}], 
     RowBox[{"{", 
      RowBox[{"A", ",", "B", ",", "C"}], "}"}]}]}], "]"}]}]], "Input",
